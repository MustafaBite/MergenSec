# ─────────────────────────────────────────────────────────
#  MergenSec — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill in values below
#  3. NEVER commit the .env file to Git!
# ─────────────────────────────────────────────────────────

# NVD API Key
# Get yours free at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=0b55042d-4696-4907-9f41-3aea1e107db1

# Database
# Default: local SQLite — no setup needed
# PostgreSQL example: postgresql://user:password@localhost/mergensec
DATABASE_URL=sqlite:///mergensec.db
